---
import ProjectsShowcase from "@/components/ProjectsShowcase";
import { getCollection } from "astro:content";

const projectEntries = await getCollection("projects");
const projects = projectEntries.map(({ data }) => ({
  title: data.title,
  image: data.image,
  description: data.description,
  link: data.link,
  year: data.year,
  role: data.role,
  tags: data.tags,
  tech: data.tech,
 
}));
---

<ProjectsShowcase client:visible projects={projects} />
