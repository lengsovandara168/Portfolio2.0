---
import HeaderExperience from "@/components/HeaderExperience";


const navItems = [
  { label: "Home", href: "#home" },
  { label: "About", href: "#about" },
  { label: "Skills", href: "#skills" },
  { label: "Projects", href: "#projects" },
  {
    label: "Contact",
    href: "https://mail.google.com/mail/?view=cm&fs=1&to=lengsovandara7@gmail.com&su=Portfolio%20Inquiry",
    cta: true,
  },
];
---
<header id="site-header" class="header-shell fixed top-0 left-0 z-50 w-full bg-transparent">
  <HeaderExperience
    client:load
    items={navItems}
  />
</header>

<style is:global>
  .header-pill {
    left: auto !important;
    right: 1rem !important;
    transform: translate3d(0, 0, 0) !important;
    transition:
      right 0.55s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }

  .header-shell.is-scrolled .header-pill {
    right: 50% !important;
    transform: translate3d(50%, 0, 0) !important;
  }

  .header-kicker {
    transition:
      opacity 0.35s ease,
      transform 0.35s ease;
  }

  .header-shell.is-scrolled .header-kicker {
    opacity: 0;
    transform: translateY(-8px);
    pointer-events: none;
  }

  @media (max-width: 1023px) {
    .header-pill,
    .header-shell.is-scrolled .header-pill,
    .header-kicker,
    .header-shell.is-scrolled .header-kicker {
      left: 0 !important;
      right: 0 !important;
      transform: none !important;
      transition: none;
    }

    .header-kicker,
    .header-shell.is-scrolled .header-kicker {
      display: none !important;
      opacity: 0;
    }
  }
</style>

<script>
  const header = document.getElementById("site-header");

  const toggleHeaderPosition = () => {
    if (!header) return;
    header.classList.toggle("is-scrolled", window.scrollY > 8);
  };

  let resizeTimer = 0;
  const onResize = () => {
    window.clearTimeout(resizeTimer);
    resizeTimer = window.setTimeout(toggleHeaderPosition, 80);
  };

  toggleHeaderPosition();

  window.addEventListener("resize", onResize, { passive: true });
  window.addEventListener("scroll", toggleHeaderPosition, { passive: true });
</script>
