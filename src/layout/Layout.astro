---

import "../styles/global.css";
import Footer from "./Footer.astro";
import Header from "./Header.astro";
---


<html lang="en" data-theme="dark">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/assets/logo/lsd_logo.png" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width" />
        <title>Leng Sovandara portfolio</title>
        <link href="https://cdn.jsdelivr.net/npm/remixicon@3.0.0/fonts/remixicon.css" rel="stylesheet">
        <script is:inline>
          (function () {
            try {
              var saved = localStorage.getItem('theme');
              var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
              var theme = saved || (prefersDark ? 'dark' : 'light');
              document.documentElement.setAttribute('data-theme', theme);
              if (theme === 'dark') {
                document.documentElement.classList.add('dark');
              } else {
                document.documentElement.classList.remove('dark');
              }
            } catch (e) {}
          })();
        </script>
    </head>
    <body class="min-h-screen overflow-x-hidden bg-[#0b1220] text-gray-100">
        <Header />
        <main class="bg-[#0b1220] focus:outline-none" tabindex="-1">
            <slot />
        </main>
        <Footer />
    </body>