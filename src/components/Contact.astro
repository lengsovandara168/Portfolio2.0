---

---
<section id="contact" class="section bg-gray-950 text-gray-100">
  <div class="container mx-auto">
    <h3 class="text-base font-medium text-center text-gray-300 mb-2">Get In<span class="text-cyan-400"> Touch </span></h3>
    <h2 class="text-3xl font-bold text-center text-white mb-8">Contact Me</h2>
    <div class="grid md:grid-cols-1">
      <form action="#" class="max-w-xl mx-auto flex flex-col gap-4 bg-gray-900 p-8 rounded-lg shadow" id="contact-form">
        <div class="flex flex-col md:flex-row gap-4">
          <input type="text" name="user_name" required placeholder="Enter your name" class="flex-1 p-3 rounded bg-gray-800 text-gray-100 focus:outline-none" />
          <input type="email" name="user_email" required placeholder="Enter your email" class="flex-1 p-3 rounded bg-gray-800 text-gray-100 focus:outline-none" />
        </div>
        <textarea name="user_project" required placeholder="Enter your message" cols="30" rows="5" class="p-3 rounded bg-gray-800 text-gray-100 focus:outline-none"></textarea>
        <p class="text-sm text-green-400 h-5" id="contact-message"></p>
        <button type="submit" class="bg-cyan-400 text-gray-900 font-semibold px-6 py-2 rounded shadow hover:bg-cyan-300 transition">Send message</button>
      </form>
    </div>
  </div>
</section>
