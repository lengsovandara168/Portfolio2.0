---

---
<section id="contact" class="section bg-[#0b1220] text-gray-100">
  <div class="mx-auto max-w-7xl px-4 pb-16 sm:px-6 lg:px-8">
    <h3 class="mb-2 text-center text-base font-medium text-gray-300">Get In<span class="text-[#e6d3aa]"> Touch </span></h3>
    <h2 class="mb-8 text-center text-3xl font-bold text-white">Contact Me</h2>
    <div class="grid md:grid-cols-1">
      <form action="#" class="mx-auto flex w-full max-w-2xl flex-col gap-4 rounded-2xl border border-white/10 bg-gray-900 p-5 shadow sm:p-8" id="contact-form">
        <div class="flex flex-col md:flex-row gap-4">
          <input type="text" name="user_name" required placeholder="Enter your name" class="min-w-0 flex-1 rounded bg-gray-800 p-3 text-gray-100 focus:outline-none" />
          <input type="email" name="user_email" required placeholder="Enter your email" class="min-w-0 flex-1 rounded bg-gray-800 p-3 text-gray-100 focus:outline-none" />
        </div>
        <textarea name="user_project" required placeholder="Enter your message" cols="30" rows="5" class="min-h-[140px] rounded bg-gray-800 p-3 text-gray-100 focus:outline-none"></textarea>
        <p class="text-sm text-green-400 h-5" id="contact-message"></p>
        <button type="submit" class="inline-flex w-full items-center justify-center rounded bg-[#c7a76c] px-6 py-3 font-semibold text-[#0b1220] shadow transition hover:bg-[#d8bd87] sm:w-fit">Send message</button>
      </form>
    </div>
  </div>
</section>
