---
// Skills section component
---
<section class="bg-gray-950 text-gray-100 py-16">
  <div class="max-w-7xl mx-auto px-4 grid md:grid-cols-2 gap-8 items-center">
    <div class="flex flex-col gap-6">
      <h3 class="text-base font-medium text-gray-300">Favorite <span class="text-cyan-400">Skills</span></h3>
      <h2 class="text-3xl font-bold text-white">My Skills</h2>
      <p class="text-gray-400 max-w-xl">
        Proficient in HTML, CSS, and JavaScript. I create responsive, visually appealing websites with a strong focus on user experience, clean design, and smooth interaction. Always improving and learning new techniques to stay creative and effective.
      </p>
      <a href="#projects" class="inline-block bg-cyan-400 text-gray-900 font-semibold px-6 py-2 rounded shadow hover:bg-cyan-300 transition-colors">See Project</a>
    </div>
    <div class="flex flex-col md:flex-row gap-8">
      <ol class="list-decimal ml-6 space-y-2">
        <li>HTML & CSS</li>
        <li>JavaScript</li>
        <li>Bootstrap</li>
        <li>Python</li>
        <li>Java</li>
      </ol>
      <ol class="list-decimal ml-6 space-y-2" start="6">
        <li>Git & GitHub</li>
        <li>Cloud</li>
        <li>Figma</li>
        <li>AWS Cloud</li>
      </ol>
    </div>
  </div>
</section>
