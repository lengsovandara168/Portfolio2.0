---
// Services section component
---
<section id="services" class="bg-gray-950 text-gray-100 py-16">
  <div class="max-w-7xl mx-auto px-4">
    <h3 class="text-base font-medium text-center text-gray-300 mb-2">My <span class="text-cyan-400">Services</span></h3>
    <h2 class="text-3xl font-bold text-center text-white mb-8">What I do</h2>
    <div class="grid md:grid-cols-4 gap-8">
      <article class="bg-gray-900 rounded-lg p-6 flex flex-col items-center shadow">
        <i class="ri-layout-masonry-fill text-4xl text-cyan-400 mb-4"></i>
        <h2 class="text-xl font-semibold mb-2">Web Developer</h2>
        <p class="text-gray-400 text-center">I design and build responsive, user-friendly websites using HTML, CSS, and JavaScript. My focus is clean UI and great UX.</p>
      </article>
      <article class="bg-gray-900 rounded-lg p-6 flex flex-col items-center shadow">
        <img width="30" height="30" src="https://img.icons8.com/ios-glyphs/30/python.png" alt="python" class="mb-4" />
        <h2 class="text-xl font-semibold mb-2">Python Automation</h2>
        <p class="text-gray-400 text-center">I write Python scripts to automate tasks, process data, and build tools that save time and improve efficiency.</p>
      </article>
      <article class="bg-gray-900 rounded-lg p-6 flex flex-col items-center shadow">
        <i class="ri-cloud-line text-4xl text-cyan-400 mb-4"></i>
        <h2 class="text-xl font-semibold mb-2">AWS Cloud Deployment</h2>
        <p class="text-gray-400 text-center">I deploy and manage web apps or services using AWS, ensuring secure and scalable cloud solutions.</p>
      </article>
      <article class="bg-gray-900 rounded-lg p-6 flex flex-col items-center shadow">
        <span class="material-symbols-outlined text-4xl text-cyan-400 mb-4">account_tree</span>
        <h2 class="text-xl font-semibold mb-2">Cisco Networking</h2>
        <p class="text-gray-400 text-center">I understand networking fundamentals and can perform basic Cisco device configuration and troubleshooting.</p>
      </article>
    </div>
  </div>
</section>
