---
// Astro Project Card component
// Props: title, description, image, tags, link
const { title, description, image, tags = [], link } = Astro.props;
---
<div class="card w-full bg-base-100 shadow-xl">
  <figure><img src={image} alt={title} class="object-cover h-48 w-full" /></figure>
  <div class="card-body">
    <h2 class="card-title">{title}</h2>
    <p>{description}</p>
    <div class="flex flex-wrap gap-2 mt-2">
      {tags.map(tag => <span class="badge badge-outline" key={tag}>{tag}</span>)}
    </div>
    <div class="card-actions justify-end mt-4">
      <a href={link} class="btn btn-primary btn-sm" target="_blank">View Project</a>
    </div>
  </div>
</div>
