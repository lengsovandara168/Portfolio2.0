---
import { getCollection } from "astro:content";
import ProjectsShowcase from "./ProjectsShowcase.jsx";

const projectEntries = await getCollection("projects");
const projects = projectEntries.map(({ data }) => ({
  title: data.title,
  image: data.image,
  description: data.description,
  link: data.link,
  highlights:
    data.highlights ?? [
      `Built around ${data.tags.slice(0, 2).join(" and ")}.`,
      "Focused on usability, clean interface design, and practical implementation.",
    ],
}));
---

<ProjectsShowcase client:visible projects={projects} />
