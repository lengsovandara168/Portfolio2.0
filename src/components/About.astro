---
// About section component
---

<section id="about" class="py-16 bg-base-200">
  <div class="max-w-5xl mx-auto px-4 flex flex-col md:flex-row gap-8 items-center">
    <div class="card w-full md:w-1/2 bg-base-100 shadow-xl">
      <figure class="px-10 pt-10">
        <div class="avatar">
          <div class="w-32 rounded-full ring ring-primary ring-offset-base-100 ring-offset-2">
            <img src="/assets/img/profile.jpg" alt="Profile" />
          </div>
        </div>
      </figure>
      <div class="card-body items-center text-center">
        <h2 class="card-title text-3xl">About Me</h2>
        <p class="text-base-content/70">I'm a front-end developer crafting sleek, user-focused web interfaces. With solid experience and satisfied clients, I turn clean design into powerful results.</p>
        <div class="card-actions mt-4">
          <a href="#contact" class="btn btn-primary">Contact Me</a>
        </div>
      </div>
    </div>
    <div class="w-full md:w-1/2">
      <ul class="timeline timeline-vertical">
        <li>
          <div class="timeline-start timeline-box">2019</div>
          <div class="timeline-middle">
            <span class="badge badge-primary">Started University</span>
          </div>
          <hr class="bg-primary" />
        </li>
        <li>
          <hr class="bg-primary" />
          <div class="timeline-end timeline-box">2022</div>
          <div class="timeline-middle">
            <span class="badge badge-secondary">First Internship</span>
          </div>
          <hr class="bg-secondary" />
        </li>
        <li>
          <hr class="bg-secondary" />
          <div class="timeline-start timeline-box">2023</div>
          <div class="timeline-middle">
            <span class="badge badge-accent">Front-end Developer</span>
          </div>
        </li>
      </ul>
    </div>
  </div>
</section>
